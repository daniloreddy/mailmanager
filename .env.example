# MailManager — environment variables
# Copy to .env and fill in values before running

# Login (cookie session auth on /ui) is always required — see scripts/set_password.py.

# Interface to bind (non-Docker runs only — ignored in Docker, see docker-compose.yml).
# Default: 127.0.0.1 (localhost only). Set to 0.0.0.0 to accept connections from
# other machines (LAN, a tunnel client running on the same host, etc.) — this is
# a deployer choice: e.g. bind 0.0.0.0 on a trusted LAN, or keep 127.0.0.1 behind
# a Cloudflare/SSH tunnel.
# HOST=127.0.0.1

# Port to listen on (default: 8080)
# PORT=8080

# Set to "1" to force Secure flag on session cookie (HTTPS only).
# Auto-detected when behind Cloudflare Tunnel (X-Forwarded-Proto: https).
# AUTH_SECURE_COOKIE=1

# Comma-separated list of trusted proxy IPs for X-Forwarded-For resolution.
# Default: 127.0.0.1
# TRUSTED_PROXIES=127.0.0.1

# IANA timezone for displaying timestamps in the UI (e.g. Europe/Rome).
# Default: UTC
# TZ=UTC

# Set to "true" to enable uvicorn --reload and expose /docs, /redoc, /openapi.json.
# Default: false
# DEV=false

# Runtime-editable settings below — hot-reload via ConfigManager (mtime polling,
# ~5s), also writable from the Settings page. Defaults shown are what applies if
# the key is absent from .env.

# Auto-refresh on the Status dashboard.
# REFRESH_ENABLED=true
# REFRESH_INTERVAL=30

# Background scheduler that processes IMAP accounts.
# SCHEDULER_ENABLED=true
# SCHEDULER_INTERVAL_SECONDS=300

# Root log level (DEBUG/INFO/WARNING/ERROR).
# LOG_LEVEL=INFO

# SpamAssassin (spamc/spamd) integration.
# SPAM_ENABLED=false
# SPAM_HOST=127.0.0.1
# SPAM_PORT=783
# SPAM_USER=
# SPAM_CONNECT_TIMEOUT_MS=3000
# SPAM_READ_TIMEOUT_MS=5000
